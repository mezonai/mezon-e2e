{
  "name": "mezon-automation",
  "version": "1.0.0",
  "type": "module",
  "description": "Automation Framework with Playwright + Page Object Model",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test --project Chrome",
    "test:all": "npx playwright test --project Chrome",
    "test:standalone": "npx playwright test --project Chrome-Standalone",
    "test:channel-management": "npx playwright test src/tests/web/ChannelManagement.spec.ts --project Chrome",
    "test:channel-message-1": "npx playwright test src/tests/web/ChannelMessage_1.spec.ts --project Chrome",
    "test:channel-message-2": "npx playwright test src/tests/web/ChannelMessage_2.spec.ts --project Chrome",
    "test:channel-message-3": "npx playwright test src/tests/web/ChannelMessage_3.spec.ts --project Chrome",
    "test:channel-message-4": "npx playwright test src/tests/web/ChannelMessage_4.spec.ts --project Chrome",
    "test:channel-message-5": "npx playwright test src/tests/web/ChannelMessage_5.spec.ts --project Chrome",
    "test:clan-management": "npx playwright test src/tests/web/ClanManagement.spec.ts --project Chrome",
    "test:direct-message": "npx playwright test src/tests/web/DirectMessage.spec.ts --project Chrome",
    "test:onboarding-guide": "npx playwright test src/tests/web/OnboardingGuide.spec.ts --project Chrome",
    "test:thread-management": "npx playwright test src/tests/web/ThreadManagement.spec.ts --project Chrome",
    "test:upload-file": "npx playwright test src/tests/web/uploadFile.spec.ts --project Chrome",
    "test:user-profile": "npx playwright test src/tests/web/UserProfile.spec.ts --project Chrome",
    "test:debug": "npx playwright test --debug",
    "test:multi": "npx playwright test --project Multi",
    "cleanup": "npx playwright test --project cleanup",
    "test:report": "npx playwright show-report --host=127.0.0.1",
    "report:playwright": "npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:open": "allure open allure-report",
    "allure:clean": "rm -rf allure-results allure-report",
    "allure:history": "npm run allure:preserve-history && npm run allure:generate && npm run allure:restore-history",
    "allure:preserve-history": "test -d allure-report/history && cp -r allure-report/history allure-results/ || echo 'No history found'",
    "allure:restore-history": "test -d allure-results/history && echo 'History preserved' || echo 'No history to restore'",
    "install:browsers": "npx playwright install",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "lint:staged": "npx lint-staged",
    "lint:report": "npx eslint src/ --ext .ts,.tsx -f eslint-formatter-sonarqube -o eslint-report.json",
    "ts-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "clean": "rm -rf test-results/ playwright-report/ coverage/ allure-results/ allure-report/",
    "prepare": "husky",
    "sonar:report": "npm run lint:report --yes && npx sonar-scanner",
    "allure:daily": "bash scripts/allure/allure-daily.sh",
    "allure:build-index": "bash scripts/allure/build-index.sh"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "page-object-model"
  ],
  "author": "Mezon Team",
  "license": "MIT",
  "devDependencies": {
    "@estruyf/github-actions-reporter": "^1.10.0",
    "@playwright/test": "^1.57.0",
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "allure-commandline": "^2.34.1",
    "allure-js-commons": "^3.3.3",
    "allure-playwright": "^3.3.3",
    "eslint": "^9.0.0",
    "eslint-formatter-sonarqube": "1.0.0",
    "eslint-plugin-sonarjs": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "mezon-js": "^2.13.16",
    "nodemon": "^3.1.10",
    "playwright-bdd": "^8.3.1",
    "prettier": "^3.3.0",
    "stop-only": "^3.1.2",
    "typescript": "^5.5.0",
    "vercel": "^54.18.5"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0",
    "archiver": "^7.0.1",
    "aws-sdk": "^2.1692.0",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{e2e,e2e-ee,spec}.{js,ts}": [
      "stop-only --file"
    ],
    "libs/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
